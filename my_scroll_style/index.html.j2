{% extends 'lab/index.html.j2' %}

{% block header %}
{{ super() }}
<style type="text/css">
  div.jp-CodeCell div.jp-InputArea-editor {
    overflow-x: auto !important;
  }

  div.jp-CodeCell pre {
    white-space: pre !important;
    word-wrap: normal !important;
  }

  @media (max-width: 768px) {
    div.jp-InputArea-editor {
      /* This ensures the cell doesn't stretch the whole page */
      max-width: 100vw; 
      display: block;
    }
  }	
</style>
{% endblock header %}

